# Django
DJANGO_SECRET_KEY=your-very-secret-key-change-this
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=voicepilot.settings.development

# Database
DATABASE_URL=postgres://voicepilot:password@localhost:5432/voicepilot_db

# Redis
REDIS_URL=redis://localhost:6379/0

# ── Plivo (telephony) ─────────────────────────────────────────────────────────
PLIVO_AUTH_ID=MAxxxxxxxxxxxxxxxxxxxxxxxxxx
PLIVO_AUTH_TOKEN=your_plivo_auth_token
PLIVO_WEBHOOK_BASE_URL=https://your-ngrok-or-domain.com

# ── LiveKit (WebRTC / SIP) ────────────────────────────────────────────────────
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxxxxxxxxx
LIVEKIT_API_SECRET=your_livekit_api_secret

# ── Deepgram (STT) ────────────────────────────────────────────────────────────
DEEPGRAM_API_KEY=your_deepgram_api_key

# ── Google AI / Gemini (LLM) ──────────────────────────────────────────────────
GOOGLE_AI_API_KEY=your_google_ai_studio_api_key

# ── Cartesia (TTS) ────────────────────────────────────────────────────────────
CARTESIA_API_KEY=your_cartesia_api_key
# Default voice — "Jessica" (neutral, professional). Browse at play.cartesia.ai
CARTESIA_VOICE_ID=a0e99841-438c-4a64-b679-ae501e7d6091

# ── Google Calendar ───────────────────────────────────────────────────────────
GOOGLE_CALENDAR_CREDENTIALS_JSON=/path/to/service-account.json

# ── Airtable ──────────────────────────────────────────────────────────────────
AIRTABLE_API_KEY=your_airtable_personal_access_token
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# ── AWS S3 (call recordings) ──────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_STORAGE_BUCKET_NAME=voicepilot-recordings
AWS_S3_REGION_NAME=ap-south-1
